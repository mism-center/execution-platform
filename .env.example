# MISM Execution Platform — Environment Configuration
# Copy to .env and edit as needed.

# --- General ---
ENV=local
DEBUG=false

# --- DAL / Registry ---
# Omit DATABASE_URL to use InMemoryRegistry (no persistence).
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/mism

# --- iRODS / Storage ---
IRODS_PVC_NAME=irods-data
IRODS_MOUNT_PATH=/irods

# --- Appstore (K8s orchestration) ---
APPSTORE_URL=http://helx-appstore:8000
APPSTORE_USERNAME=admin
APPSTORE_PASSWORD=admin

# --- Ambassador ingress (interactive session URLs) ---
AMBASSADOR_URL=https://mism-apps.apps.renci.org
