# MISM Execution Platform — Environment Configuration
# Copy to .env and edit as needed.

# --- General ---
ENV=local
DEBUG=false

# --- Kubernetes ---
NAMESPACE=default
SERVICE_ACCOUNT=default
AMBASSADOR_ENABLED=true
# Set to true to use in-memory stub instead of real K8s (for local dev)
STUB_COMPUTE=false

# --- DAL / Registry ---
# Omit for InMemoryRegistry (no persistence). Set for Postgres:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/mism

# --- iRODS Storage ---
IRODS_PVC_NAME=irods-data

# --- Vivarium PoC ---
VIVARIUM_IMAGE=containers.renci.org/mism/vivarium-jupyter:latest

# --- Authentication (not enforced yet) ---
AUTH_ENABLED=false
# OIDC_ISSUER_URL=https://keycloak.example.com/realms/mism
# OIDC_AUDIENCE=mism-exec

# --- GPU (skipped for PoC) ---
GPU_RESOURCE_NAME=nvidia.com/gpu
