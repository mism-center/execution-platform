# Copy this file to scripts/.env and fill in the values.
# Load with: export $(cat scripts/.env | xargs)

# Postgres connection (port-forward metadata-store before running)
MISM_DB_URL=postgresql+psycopg2://<user>:<password>@localhost:<port>/<db>

# Execution platform base URL
MISM_EXEC_API=https://<execution-platform-host>

# Container image for the test model
MISM_MODEL_IMAGE=<registry>/<image>@sha256:<digest>

# Path to the notebook inside the container (batch + deployed tests)
MISM_NOTEBOOK_PATH=/home/jovyan/notebooks/<notebook>.ipynb
